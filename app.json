{
  "name": "SHAHBAZ-MD",
  "description": "SHAHBAZ WhatsApp Bot",
  "logo": "https://files.catbox.moe/jojm9q.png",
  "keywords": [
    "whatsapp",
    "bot",
    "SHABAZ-MD"
  ],
  "repository": "https://github.com/shahzebyc3/SHAHBAZ-MD",
  "stack": "container",
  "env": {
    "MONGO_URL": {
      "description": "Put if you have mongodb database url",
      "required": false,
      "value": ""
    },
    "MYSQL_URL": {
      "description": "Put if you have mysql database url",
      "required": false,
      "value": ""
    },
    "POSTGRES_URL": {
      "description": "Put if you have postgres database url",
      "required": false,
      "value": ""
    },
    "HKEY": {
      "description": "Put your Heroku api key Here",
      "required": true
    },
    "HAPP": {
      "description": "Put your Heroku app name",
      "required": true
    },
    "SESSION_ID": {
      "description": "Put your session id",
      "required": true
    },
    "REMOVEBG_KEY": {
      "description": "Put your RemoveBG api key",
      "required": false,
      "value": ""
    }
  },
  "buildpacks": [
    {
      "url": "heroku/nodejs"
    },
    {
      "url": "https://github.com/DuckyTeam/heroku-buildpack-imagemagick.git"
    },
    {
      "url": "https://github.com/jonathanong/heroku-buildpack-ffmpeg-latest"
    },
    {
      "url": "https://github.com/clhuang/heroku-buildpack-webp-binaries.git"
    }
  ],
  "formation": {
    "web": {
      "quantity": 1,
      "size": "basic"
    }
  }
}
